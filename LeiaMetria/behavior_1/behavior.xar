            <Box name="Program" id="1" localization="8" tooltip="" x="249" y="62">
              <bitmap>media/images/box/box-python-script.png</bitmap>
              <script language="4">
                <content>
                  <![CDATA[class MyClass(GeneratedClass):
    def onLoad(self):
        import threading
        import socket

        self.tts     = self.session().service("ALTextToSpeech")
        self.motion  = self.session().service("ALMotion")
        self.posture = self.session().service("ALRobotPosture")

        self.flask_ip      = "192.168.0.21"
        self.flask_port    = 5000
        self.polling_ativo = True

        try:
            self.tablet = self.session().service("ALTabletService")
            self.has_tablet = True
        except:
            self.tablet     = None
            self.has_tablet = False

        try:
            hostname      = socket.gethostname()
            self.local_ip = socket.gethostbyname(hostname)
        except Exception as e:
            self.logger.error("ERRO IP: " + str(e))

        self.poll_thread = threading.Thread(target=self.polling_fala)
        self.poll_thread.daemon = True
        self.poll_thread.start()
        self.logger.info("Polling iniciado")

    # ─────────────────────────────────────────
    # POLLING
    # ─────────────────────────────────────────
    def polling_fala(self):
        import urllib2
        import json
        import time

        while self.polling_ativo:
            try:
                url      = "http://{}:{}/checar_fala".format(self.flask_ip, self.flask_port)
                response = urllib2.urlopen(url, timeout=3)
                data     = json.loads(response.read())

                if data.get("falar"):
                    texto = data.get("texto", "")
                    tipo  = data.get("tipo",  "")

                    if isinstance(texto, unicode):
                        texto = texto.encode("utf-8")
                    if isinstance(tipo, unicode):
                        tipo = tipo.encode("utf-8")

                    self.logger.info("Tipo: " + tipo)

                    # 🔥 dispara o output — Choregraphe roteia para o behavior
                    if   tipo == "aguardando":  self.aguardando()
                    elif tipo == "acerto":      self.acerto()
                    elif tipo == "erro":        self.erro()
                    elif tipo == "explicacao":  self.explicacao()

                    self.tts.say(texto)

            except Exception as e:
                self.logger.error("Erro no polling: " + str(e))

            time.sleep(1)

    # ─────────────────────────────────────────
    # LIFECYCLE
    # ─────────────────────────────────────────
    def onUnload(self):
        self.polling_ativo = False
        try:
            self.motion.stopMove()
        except:
            pass

    def onInput_onStart(self):
        import time
        import os

        self.motion.wakeUp()
        self.posture.goToPosture("StandInit", 0.5)
        time.sleep(1)

        flask_url = "http://{}:{}/".format(self.flask_ip, self.flask_port)

        if self.has_tablet:
            try:
                self.tablet.showWebview(flask_url)
            except Exception as e:
                self.logger.error("Erro no tablet: " + str(e))
        else:
            try:
                os.startfile(flask_url)
            except:
                try:
                    import webbrowser
                    webbrowser.open(flask_url)
                except Exception as e:
                    self.logger.error("webbrowser falhou: " + str(e))

        # 🔥 sem onStopped — fica vivo

    def onInput_onStop(self):
        if self.has_tablet and self.tablet:
            try:
                self.tablet.hideWebview()
            except:
                pass
        self.onUnload()
        self.onStopped()

    # ─────────────────────────────────────────
    # 🔥 OUTPUTS declarados como inputs no XML
    # Choregraphe gera automaticamente:
    # self.aguardando() self.acerto()
    # self.erro()       self.explicacao()
    # ─────────────────────────────────────────]]>
                </content>
              </script>
