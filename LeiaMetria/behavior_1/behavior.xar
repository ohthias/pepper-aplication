            <Box name="LEDs" id="9" localization="8" tooltip="" x="151" y="309">
              <bitmap>media/images/bonjour/robot_on.png</bitmap>
              <script language="4">
                <content>
                  <![CDATA[class MyClass(GeneratedClass):
    def onLoad(self):
        self.leds = self.session().service("ALLeds")

    def onUnload(self):
        # volta ao branco ao encerrar
        self.leds.fadeRGB("FaceLeds", 0x00FFFFFF, 0.5)
        self.leds.fadeRGB("EarLeds",  0x00FFFFFF, 0.5)
        self.leds.fadeRGB("ChestLeds",0x00FFFFFF, 0.5)

    # ─────────────────────────────────────────
    # UTILITÁRIOS — mesma assinatura do script
    # leds.fadeRGB(grupo, 0x00RRGGBB, duracao)
    # ─────────────────────────────────────────
    def _olhos(self, cor_hex, duracao=0.3):
        self.leds.fadeRGB("FaceLeds", cor_hex, duracao)

    def _orelhas(self, cor_hex, duracao=0.3):
        self.leds.fadeRGB("EarLeds", cor_hex, duracao)

    def _peito(self, cor_hex, duracao=0.3):
        self.leds.fadeRGB("ChestLeds", cor_hex, duracao)

    def _reset(self, duracao=0.5):
        self.leds.fadeRGB("FaceLeds",  0x00FFFFFF, duracao)
        self.leds.fadeRGB("EarLeds",   0x00FFFFFF, duracao)
        self.leds.fadeRGB("ChestLeds", 0x00FFFFFF, duracao)

    def _pulsar_olhos(self, cor_hex, vezes=2, duracao=0.3):
        import time
        for _ in range(vezes):
            self.leds.fadeRGB("FaceLeds", cor_hex,   duracao)
            time.sleep(duracao)
            self.leds.fadeRGB("FaceLeds", 0x00000000, duracao * 0.6)
            time.sleep(duracao * 0.6)
        self.leds.fadeRGB("FaceLeds", cor_hex, duracao)

    def _pulsar_orelhas(self, cor_hex, vezes=2, duracao=0.2):
        import time
        for _ in range(vezes):
            self.leds.fadeRGB("EarLeds", 0x00000000, duracao)
            time.sleep(duracao)
            self.leds.fadeRGB("EarLeds", cor_hex,    duracao)
            time.sleep(duracao)

    def _pulsar_peito(self, cor_hex, vezes=2, duracao=0.2):
        import time
        for _ in range(vezes):
            self.leds.fadeRGB("ChestLeds", 0x00000000, duracao)
            time.sleep(duracao)
            self.leds.fadeRGB("ChestLeds", cor_hex,    duracao)
            time.sleep(duracao)

    # ─────────────────────────────────────────
    # PALETA — cores em hex 0x00RRGGBB
    # ─────────────────────────────────────────
    # AZUL       0x000000FF  — aguardando
    # AMARELO    0x00FFD700  — explicacao
    # VERDE      0x0000FF00  — acerto
    # LARANJA    0x00FF7300  — erro (empatia)
    # BRANCO     0x00FFFFFF  — neutro/reset
    # PRETO      0x00000000  — apagado

    # ─────────────────────────────────────────
    # LED AGUARDANDO — azul receptivo
    # ─────────────────────────────────────────
    def led_aguardando(self):
        import time

        self._olhos( 0x000066FF, 0.5)
        self._orelhas(0x000044CC, 0.5)
        self._peito( 0x00003399, 0.5)
        time.sleep(0.6)

        # pulsa devagar — respiração de espera
        self._pulsar_olhos(0x000066FF, vezes=2, duracao=0.5)
        time.sleep(0.3)

        # orelhas piscam convidando
        self._pulsar_orelhas(0x000066FF, vezes=2, duracao=0.35)

        # estabiliza
        self._olhos( 0x000066FF, 0.4)
        self._orelhas(0x000044CC, 0.4)

    # ─────────────────────────────────────────
    # LED EXPLICAÇÃO — amarelo didático
    # ─────────────────────────────────────────
    def led_explicacao(self):
        import time

        self._olhos( 0x00FFD700, 0.4)
        self._orelhas(0x00CC9900, 0.4)
        self._peito( 0x00AA6600, 0.4)
        time.sleep(0.5)

        # pulsa levemente ao longo da explicação
        self._pulsar_olhos(0x00FFD700, vezes=1, duracao=0.5)
        time.sleep(0.4)

        # brilho total ao concluir
        self._olhos( 0x00FFEE88, 0.35)
        self._orelhas(0x00FFFFFF, 0.35)
        self._peito( 0x00FFD700, 0.35)
        time.sleep(0.5)

        # suaviza de volta
        self._olhos( 0x00FFD700, 0.5)
        self._orelhas(0x00CC9900, 0.5)
        self._peito( 0x00AA6600, 0.5)

    # ─────────────────────────────────────────
    # LED ACERTO — verde vibrante com euforia
    # ─────────────────────────────────────────
    def led_acerto(self):
        import time

        # verde imediato — vitória!
        self._olhos( 0x0000FF44, 0.2)
        self._orelhas(0x0000DD33, 0.2)
        self._peito( 0x0000BB22, 0.2)
        time.sleep(0.3)

        # pulsa rápido — euforia
        self._pulsar_olhos(0x0000FF44, vezes=3, duracao=0.22)
        time.sleep(0.2)

        # orelhas piscam
        self._pulsar_orelhas(0x0000FF44, vezes=3, duracao=0.15)
        time.sleep(0.2)

        # peito pulsa
        self._pulsar_peito(0x0000FF44, vezes=2, duracao=0.15)
        time.sleep(0.2)

        # estabiliza no verde
        self._olhos( 0x0000CC33, 0.4)
        self._orelhas(0x0000CC33, 0.4)
        self._peito( 0x0000CC33, 0.4)
        time.sleep(0.8)

        self._reset(0.7)

    # ─────────────────────────────────────────
    # LED ERRO — laranja empático → azul encorajador
    # ─────────────────────────────────────────
    def led_erro(self):
        import time

        # laranja suave — empatia
        self._olhos( 0x00FF7300, 0.5)
        self._orelhas(0x00CC5500, 0.5)
        self._peito( 0x00AA4400, 0.5)
        time.sleep(0.7)

        # pulsa uma vez (reconhece o erro)
        self._pulsar_olhos(0x00FF7300, vezes=1, duracao=0.4)
        time.sleep(0.4)

        # transição para azul — encorajamento
        self._olhos( 0x002288FF, 0.7)
        self._peito( 0x001166CC, 0.7)
        self._orelhas(0x001166CC, 0.6)
        time.sleep(0.5)

        # pulsa azul suave (você consegue!)
        self._pulsar_olhos(0x002288FF, vezes=2, duracao=0.35)
        time.sleep(0.3)

        # orelhas piscam encorajando
        self._pulsar_orelhas(0x002288FF, vezes=2, duracao=0.25)
        time.sleep(0.3)

        # estabiliza no azul
        self._olhos( 0x002288FF, 0.4)
        self._orelhas(0x001166CC, 0.4)
        self._peito( 0x001166CC, 0.4)
        time.sleep(0.5)

        self._reset(0.7)

    # ─────────────────────────────────────────
    # INPUTS — um para cada estado
    # ─────────────────────────────────────────
    def onInput_aguardando(self):
        self.led_aguardando()
        self.onStopped()

    def onInput_explicacao(self):
        self.led_explicacao()
        self.onStopped()

    def onInput_acerto(self):
        self.led_acerto()
        self.onStopped()

    def onInput_erro(self):
        self.led_erro()
        self.onStopped()

    def onInput_reset(self):
        self._reset(0.5)
        self.onStopped()

    def onInput_onStop(self):
        self.onUnload()
        self.onStopped()]]>
                </content>
              </script>
              <Input name="onLoad" type="1" type_size="1" nature="0" inner="1" tooltip="Signal sent when diagram is loaded." id="1" />
              <Input name="onStart" type="1" type_size="1" nature="2" inner="0" tooltip="Box behavior starts when a signal is received on this input." id="2" />
              <Input name="onStop" type="1" type_size="1" nature="3" inner="0" tooltip="Box behavior stops when a signal is received on this input." id="3" />
