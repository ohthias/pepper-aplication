{
  "ensinoFundamentalI": {
    "quadrado": {
      "explicacao": {
        "texto": "O quadrado possui 4 lados iguais. A área representa o espaço interno e é calculada multiplicando o lado por ele mesmo."
      },
      "formula": "A = l × l",
      "perguntas": {
        "01": {
          "texto": "Um tapete quadrado tem lado de 4 m. Quantos metros quadrados ele ocupa?",
          "correta": "b",
          "respostas": {
            "a": "8 m²",
            "b": "16 m²",
            "c": "12 m²",
            "d": "4 m²"
          },
          "dicas": {
            "1": "Área mede o espaço interno.",
            "2": "Multiplique lado × lado.",
            "3": "4 × 4 = ?",
            "gabarito": "16 m²"
          }
        },
        "02": {
          "texto": "Um quadrado tem área de 9 cm². Qual o tamanho do lado?",
          "correta": "a",
          "respostas": {
            "a": "3 cm",
            "b": "4 cm",
            "c": "2 cm",
            "d": "6 cm"
          },
          "dicas": {
            "1": "Procure um número que multiplicado por ele mesmo dá 9.",
            "2": "Teste valores pequenos.",
            "gabarito": "3 cm"
          }
        },
        "03": {
          "texto": "Dois quadrados de lado 2 cm são unidos. Qual a área total?",
          "correta": "c",
          "respostas": {
            "a": "2 cm²",
            "b": "4 cm²",
            "c": "8 cm²",
            "d": "6 cm²"
          },
          "dicas": {
            "1": "Área de um quadrado: 2×2.",
            "2": "Depois multiplique por 2.",
            "gabarito": "4 + 4 = 8 cm²"
          }
        }
      }
    },

    "triangulo": {
      "explicacao": {
        "texto": "O triângulo tem 3 lados. Sua área é metade da área de um retângulo com mesma base e altura."
      },
      "formula": "A = (b × h) / 2",
      "perguntas": {
        "01": {
          "texto": "Base 6 cm e altura 2 cm. Qual a área?",
          "correta": "d",
          "respostas": {
            "a": "6 cm²",
            "b": "3 cm²",
            "c": "8 cm²",
            "d": "6 cm²"
          },
          "dicas": {
            "1": "Multiplique base × altura.",
            "2": "Divida por 2.",
            "gabarito": "(6×2)/2 = 6 cm²"
          }
        },
        "02": {
          "texto": "Um triângulo tem área 12 cm² e base 4 cm. Qual a altura?",
          "correta": "b",
          "respostas": {
            "a": "3 cm",
            "b": "6 cm",
            "c": "4 cm",
            "d": "8 cm"
          },
          "dicas": {
            "1": "Multiplique área por 2.",
            "2": "Depois divida pela base.",
            "gabarito": "12×2 = 24 → 24÷4 = 6 cm"
          }
        },
        "03": {
          "texto": "Se a base de um triângulo dobra, a área:",
          "correta": "c",
          "respostas": {
            "a": "permanece",
            "b": "diminui",
            "c": "dobra",
            "d": "triplica"
          },
          "dicas": {
            "1": "Veja a fórmula.",
            "2": "Base está multiplicando.",
            "gabarito": "Dobra"
          }
        }
      }
    },

    "circulo": {
      "explicacao": {
        "texto": "O círculo é uma figura redonda. Sua área depende do raio."
      },
      "formula": "A = π × r²",
      "perguntas": {
        "01": {
          "texto": "Raio 2 cm. Área (π≈3)?",
          "correta": "a",
          "respostas": {
            "a": "12",
            "b": "6",
            "c": "4",
            "d": "8"
          },
          "dicas": {
            "1": "2²=4",
            "2": "4×3=12",
            "gabarito": "12"
          }
        },
        "02": {
          "texto": "Área 27 cm² (π≈3). Qual o raio?",
          "correta": "b",
          "respostas": {
            "a": "2",
            "b": "3",
            "c": "4",
            "d": "6"
          },
          "dicas": {
            "1": "Divida por 3.",
            "2": "Depois raiz quadrada.",
            "gabarito": "r=3"
          }
        },
        "03": {
          "texto": "Se o raio dobra, a área:",
          "correta": "d",
          "respostas": {
            "a": "dobra",
            "b": "triplica",
            "c": "permanece",
            "d": "quadruplica"
          },
          "dicas": {
            "1": "O raio está ao quadrado.",
            "2": "(2r)² = 4r²",
            "gabarito": "Quadruplica"
          }
        }
      }
    }
  },

